# ==========================================================
# MODELO de variaveis de ambiente.
# Copie este arquivo para .env e preencha com os valores reais.
# O .env real NUNCA deve subir no GitHub (ja esta no .gitignore).
# Em producao (GitHub Actions), use os Secrets do repositorio.
# ==========================================================

# --- ESTOCA (WMS) - leitura de estoque ---
BASE_URL_ESTOCA=https://api.estoca.com.br
ESTOCA_ENDPOINT=/inventories
API_KEY_ESTOCA=            # <-- PENDENTE: aguardando chamado da Estoca
WAREHOUSE=                 # <-- PENDENTE: aguardando chamado da Estoca

# --- OMIE (ERP) - escrita de estoque - Filial 002 ---
OMIE_PRODUTO_URL=https://app.omie.com.br/api/v1/geral/produtos/
OMIE_ESTOQUE_URL=https://app.omie.com.br/api/v1/estoque/ajuste/
APP_KEY_OMIE=
APP_SECRET=
